# --- Essential Site Configuration ---
# Your primary domain (e.g., example.com). Used to derive ALLOWED_HOSTS, CORS, and CSRF settings.
DOMAIN="localhost"

# Signs the SimpleJWT-compatible tokens. Set to a long, random string in
# production. Keep it CONSTANT across deploys/restarts or all tokens invalidate.
SECRET_KEY="replace-this-in-production"

# --- Background jobs (Rust in-process scheduler) ---
# Lets the backend own api_job scheduling. EXACTLY ONE running instance may set
# this true, or scheduled jobs fire twice against the shared DB.
RUST_ENABLE_SCHEDULER=true

# Set `Secure` on auth cookies (true in production).
JWT_AUTH_COOKIE_SECURE=true

# tracing/log filter for the Rust backend.
# RUST_LOG=info,holy_backend_rs=info,sea_orm=warn

# --- Advanced Networking (Optional, derived from DOMAIN if unset) ---
# CORS_ALLOWED_ORIGINS=https://example.com
# FRONTEND_URL=https://example.com
# VITE_API_URL=https://example.com/api/

# --- SMTP Configuration (Required for Email Verification) ---
# For development, if EMAIL_HOST is empty, emails are printed to the console.
EMAIL_HOST=
EMAIL_PORT=587
# Use EMAIL_USE_TLS=true for STARTTLS (usually port 587)
EMAIL_USE_TLS=true
# Use EMAIL_USE_SSL=true for implicit SSL (usually port 465)
EMAIL_USE_SSL=false
EMAIL_HOST_USER="your-email@example.com"
EMAIL_HOST_PASSWORD="your-password"
# Set to 'true' if using a self-signed certificate (e.g. local SMTP server)
EMAIL_SKIP_CERT_VERIFICATION=false

# --- Frontend Configuration ---
# Optional: defaults to ${DOMAIN}/api/ if not set
# VITE_API_URL=https://example.com/api/
VITE_ALLOWED_HOSTS=localhost

# --- Impressum / Contact Details (Required for German Law § 5 TMG) ---
VITE_IMPRESSUM_NAME="Your First and Last Name"
VITE_IMPRESSUM_STREET="Street Name and House Number"
VITE_IMPRESSUM_CITY="Postal Code and City"
VITE_IMPRESSUM_EMAIL="your-public-contact@email.com"
VITE_IMPRESSUM_PHONE="+00 123 456789"
