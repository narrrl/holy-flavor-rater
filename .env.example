# Example SMTP Configuration for Holy Flavors
# Rename this file to .env and fill in your details to enable email sending.

# --- Required for SMTP ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password

# --- Optional (defaults are usually fine) ---
# EMAIL_USE_TLS=true
