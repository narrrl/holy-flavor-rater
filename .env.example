# --- App Hosting ---
# A comma-separated list of hostnames that the Vite dev server will accept.
# Required if you are accessing the frontend via a custom domain.
# Example: VITE_ALLOWED_HOSTS=holy.narl.io,localhost
VITE_ALLOWED_HOSTS=localhost

# A comma-separated list of domains that can access the backend API.
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://holy.narl.io
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# A comma-separated list of hostnames that the Django backend will serve.
# Example: ALLOWED_HOSTS=localhost,backend,api.holy.narl.io
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Set to "false" in production
DEBUG=true


# A comma-separated list of domains that Django will trust for CSRF purposes.
# This should match your frontend domain.
# Example: CSRF_TRUSTED_ORIGINS=https://holy.narl.io,http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# --- SMTP Configuration ---
# Rename this file to .env and fill in your details to enable email sending.

# --- Required for SMTP ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
# Do not wrap the password in quotes or backticks
EMAIL_HOST_PASSWORD=your-app-password

# --- Optional (defaults are usually fine) ---
# EMAIL_USE_TLS=true
# For providers like Gmail using port 465, you might need to set this to true
# EMAIL_USE_SSL=true
