# --- App Hosting ---
# A comma-separated list of domains that can access the backend API.
# Example: CORS_ALLOWED_ORIGINS=http://localhost:5173,https://holy.narl.io
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# A comma-separated list of hostnames that the Django backend will serve.
# Example: ALLOWED_HOSTS=localhost,backend,api.holy.narl.io
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Set to "false" in production
DEBUG=true


# --- SMTP Configuration ---
# Rename this file to .env and fill in your details to enable email sending.

# --- Required for SMTP ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password

# --- Optional (defaults are usually fine) ---
# EMAIL_USE_TLS=true
